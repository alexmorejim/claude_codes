# Copia este archivo a .env y rellena tus llaves.
# Llaves GRATIS en https://alpaca.markets — el modo paper NO requiere fondear.

ALPACA_KEY=tu_api_key_id
ALPACA_SECRET=tu_api_secret

# true  = dinero de PRÁCTICA (paper, sin riesgo)
# false = DINERO REAL (requiere cuenta fondeada + llaves "live")
ALPACA_PAPER=true

# Opcionales
TRADER_TOP_N=4
TRADER_UNIVERSE=AAPL,MSFT,NVDA,GOOGL,META,AMZN,TSLA
