# Copia a .env y rellena. El .env NUNCA se sube (está en .gitignore).

# Wallet de Polygon con USDC. >>> USA UNA WALLET DEDICADA con poco saldo <<<
# Quien tenga esta llave controla TODOS los fondos de esa wallet. Nunca la compartas.
POLY_PRIVATE_KEY=0xtu_llave_privada

# Opcional: para SOLO leer posiciones sin poner la llave, pon aquí tu dirección pública.
POLY_ADDRESS=

# Si depositaste desde la web de Polymarket usas una "wallet proxy":
#   POLY_FUNDER = esa dirección proxy (la que ves en Polymarket)
#   POLY_SIGNATURE_TYPE = 1 (email/Magic) o 2 (wallet de navegador)
# Si tu llave controla directo un EOA que ya tiene USDC, deja ambos vacíos.
POLY_FUNDER=
POLY_SIGNATURE_TYPE=

# ---------- regla de auto-bet ----------
AUTOBET_QUERY=             # filtra por palabra en la pregunta (vacío = todos)
AUTOBET_SIDE=favorite      # favorite | longshot | yes | no
AUTOBET_MIN_PRICE=0.80     # banda de precio del resultado elegido (0-1)
AUTOBET_MAX_PRICE=0.97
AUTOBET_STAKE_USD=2        # cuánto apostar por mercado
AUTOBET_MAX_BETS=3         # máximo de apuestas por corrida
AUTOBET_BUDGET_USD=6       # tope total por corrida
AUTOBET_MIN_VOLUME=20000   # ignora mercados con poco volumen 24h
